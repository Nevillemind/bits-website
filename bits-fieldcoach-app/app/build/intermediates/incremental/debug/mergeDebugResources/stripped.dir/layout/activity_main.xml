<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:padding="24dp">

    <!-- BITS Logo + Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BITS FIELD COACH"
        android:textColor="#1A56DB"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Blockchain Integrative Technology Solutions"
        android:textColor="#64748B"
        android:textSize="10sp"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="2dp" />

    <!-- Mode Toggle Button -->
    <Button
        android:id="@+id/modeButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="MODE: FIELD COACH"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:backgroundTint="#dc3246"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:cornerRadius="18dp"
        app:layout_constraintTop_toBottomOf="@id/subtitleText"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp" />

    <!-- Connection Status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textColor="#94A3B8"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/modeButton"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Battery -->
    <TextView
        android:id="@+id/batteryText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#16A34A"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/modeButton"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Connect Button -->
    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Connect Glasses"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#1A56DB"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        android:layout_marginTop="24dp"
        app:cornerRadius="12dp" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E293B"
        app:layout_constraintTop_toBottomOf="@id/connectButton"
        android:layout_marginTop="24dp" />

    <!-- Transcript (what user said) -->
    <TextView
        android:id="@+id/transcriptLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TRANSCRIPT"
        android:textColor="#64748B"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/transcriptText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Waiting for voice input..."
        android:textColor="#E2E8F0"
        android:textSize="16sp"
        android:minLines="2"
        android:maxLines="4"
        app:layout_constraintTop_toBottomOf="@id/transcriptLabel"
        android:layout_marginTop="8dp" />

    <!-- Response (what AI said) -->
    <TextView
        android:id="@+id/responseLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FIELD COACH"
        android:textColor="#1A56DB"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/transcriptText"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/responseText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:text="Ready. Speak a question or say 'photo' to use camera."
        android:textColor="#CBD5E1"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.4"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/responseLabel"
        app:layout_constraintBottom_toTopOf="@id/footerText"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Button Row -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/footerText"
        android:layout_marginBottom="16dp">

        <!-- CAMERA BUTTON -->
        <Button
            android:id="@+id/cameraButton"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:text="CAM"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#475569"
            app:cornerRadius="50dp"
            android:layout_marginEnd="24dp" />

        <!-- MIC BUTTON — Push to Talk -->
        <Button
            android:id="@+id/micButton"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="MIC"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#1A56DB"
            app:cornerRadius="60dp" />

    </LinearLayout>

    <!-- Debug Log -->
    <TextView
        android:id="@+id/debugText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#F59E0B"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:maxLines="10"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toTopOf="@id/footerText"
        android:layout_marginBottom="4dp" />

    <!-- Footer -->
    <TextView
        android:id="@+id/footerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A BITS Corp Product | bitsfieldcoach.com"
        android:textColor="#475569"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
