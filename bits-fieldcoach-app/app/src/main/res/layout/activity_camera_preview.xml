<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0e17">

    <!-- Live Camera Feed -->
    <ImageView
        android:id="@+id/previewImage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:background="#0a0e17"
        android:contentDescription="Glasses camera feed"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/questionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#1a1e2e"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Branding -->
        <TextView
            android:id="@+id/brandingText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BITS FIELD COACH — LIVE"
            android:textColor="#dc3246"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- Connection Dot -->
        <View
            android:id="@+id/connectionDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_disconnected"
            android:layout_marginEnd="8dp" />

        <!-- Connection Status -->
        <TextView
            android:id="@+id/connectionStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disconnected"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginEnd="16dp" />

        <!-- Battery -->
        <TextView
            android:id="@+id/batteryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#16A34A"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Frame Counter Overlay (top-right of preview) -->
    <TextView
        android:id="@+id/frameCountText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Frame 0"
        android:textColor="#dc3246"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:background="#aa000000"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp" />

    <!-- No Signal Placeholder Text -->
    <TextView
        android:id="@+id/noSignalText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No glasses feed\nConnect glasses and tap Start Preview"
        android:textColor="#475569"
        android:textSize="16sp"
        android:textAlignment="center"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- AI Response Text (bottom of preview area) -->
    <TextView
        android:id="@+id/aiResponseText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#E2E8F0"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.3"
        android:background="#cc0a0e17"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:maxLines="12"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/questionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Question Input Bar -->
    <LinearLayout
        android:id="@+id/questionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="#1a1e2e"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Question text input -->
        <EditText
            android:id="@+id/questionInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Ask a question... (or tap 🎤)"
            android:textColor="#E2E8F0"
            android:textColorHint="#64748B"
            android:textSize="14sp"
            android:background="#0F172A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:inputType="text"
            android:layout_marginEnd="8dp" />

        <!-- Mic button for voice question -->
        <Button
            android:id="@+id/micButton"
            android:layout_width="48dp"
            android:layout_height="44dp"
            android:text="🎤"
            android:textSize="20sp"
            android:backgroundTint="#16A34A"
            app:cornerRadius="8dp" />

    </LinearLayout>

    <!-- Bottom Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:background="#1a1e2e"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button -->
        <Button
            android:id="@+id/backButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="BACK"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#1E293B"
            app:cornerRadius="8dp"
            android:layout_marginEnd="8dp" />

        <!-- Take Photo Button -->
        <Button
            android:id="@+id/startStopButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.5"
            android:text="📸 TAKE PHOTO"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#dc3246"
            app:cornerRadius="8dp"
            android:layout_marginEnd="8dp" />

        <!-- GO LIVE Button — starts/stops live video stream to supervisor -->
        <Button
            android:id="@+id/goLiveButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.2"
            android:text="GO LIVE"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#B91C1C"
            app:cornerRadius="8dp"
            android:layout_marginEnd="8dp" />

        <!-- Ask AI Button -->
        <Button
            android:id="@+id/askAiButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.2"
            android:text="ASK AI"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#1A56DB"
            app:cornerRadius="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
